# Copy this file to .env and fill in your values.
# The backend reads .env on startup so you don't need to set vars in the shell.

# PostgreSQL (required for predictions, logs, admin dashboard)
DATABASE_URL=postgresql://user:password@host:port/dbname

# JWT secret for auth tokens (change in production)
JWT_SECRET=project-titan-secret-change-in-prod

# Email Configuration for Contact Form
# SMTP Server Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Admin email to receive contact form submissions
ADMIN_EMAIL=admin@nanotox.ai

# Note: For Gmail, you need to use an App Password, not your regular password
# Generate App Password: https://myaccount.google.com/apppasswords
